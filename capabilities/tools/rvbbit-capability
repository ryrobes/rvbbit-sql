#!/usr/bin/env python3
"""Render and scaffold Rvbbit capability manifests.

The tool is intentionally dependency-light. YAML manifests require PyYAML;
JSON manifests work with the Python standard library.
"""
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[1]
TEMPLATES = ROOT / "templates"


def load_manifest(path: Path) -> dict[str, Any]:
    text = path.read_text()
    if path.suffix.lower() == ".json":
        data = json.loads(text)
    else:
        try:
            import yaml  # type: ignore
        except Exception as exc:  # pragma: no cover - depends on local env
            raise SystemExit(
                "YAML manifests require PyYAML. Use a .json manifest or install pyyaml."
            ) from exc
        data = yaml.safe_load(text)
    if not isinstance(data, dict):
        raise SystemExit(f"{path}: manifest must be an object")
    validate_manifest(data, path)
    return data


def validate_manifest(manifest: dict[str, Any], path: Path) -> None:
    required = ["api_version", "kind", "name"]
    missing = [key for key in required if key not in manifest]
    if missing:
        raise SystemExit(f"{path}: missing required field(s): {', '.join(missing)}")
    if manifest["api_version"] != "rvbbit.capability/v1":
        raise SystemExit(f"{path}: unsupported api_version {manifest['api_version']!r}")
    if manifest["kind"] not in {"hf_backend", "runtime_sidecar"}:
        raise SystemExit(f"{path}: unsupported kind {manifest['kind']!r}")
    if manifest["kind"] == "hf_backend":
        backend = manifest.get("backend")
        if not isinstance(backend, dict) or not backend.get("name"):
            raise SystemExit(f"{path}: backend.name is required")
    if manifest["kind"] == "runtime_sidecar":
        runtime = manifest.get("runtime")
        if not isinstance(runtime, dict) or not runtime.get("language"):
            raise SystemExit(f"{path}: runtime.language is required")
        registration = manifest.get("runtime_registration")
        if not isinstance(registration, dict) or not registration.get("name"):
            raise SystemExit(f"{path}: runtime_registration.name is required")
    operators = manifest.get("operators") or []
    if not isinstance(operators, list):
        raise SystemExit(f"{path}: operators must be a list")
    for op in operators:
        if not isinstance(op, dict):
            raise SystemExit(f"{path}: each operator must be an object")
        for key in ["name", "arg_names", "return_type"]:
            if key not in op:
                raise SystemExit(f"{path}: operator missing {key}")
        if op.get("arg_types") and len(op["arg_types"]) != len(op["arg_names"]):
            raise SystemExit(f"{path}: operator {op['name']} arg_types length mismatch")


def sql_lit(value: Any) -> str:
    if value is None:
        return "NULL"
    return "'" + str(value).replace("'", "''") + "'"


def sql_json(value: Any) -> str:
    return sql_lit(json.dumps(value, sort_keys=True, separators=(",", ":"))) + "::jsonb"


def sql_text_array(values: list[str]) -> str:
    inner = ",".join(sql_lit(value) for value in values)
    return f"ARRAY[{inner}]"


def backend_endpoint(manifest: dict[str, Any]) -> str:
    backend = manifest["backend"]
    if backend.get("endpoint"):
        return backend["endpoint"]
    service = manifest["name"].replace("_", "-")
    return f"http://{service}:8080/predict"


def install_manifest(manifest: dict[str, Any]) -> dict[str, Any]:
    keep = {
        key: manifest[key]
        for key in [
            "api_version",
            "kind",
            "name",
            "title",
            "description",
            "license",
            "tags",
            "source",
            "runtime",
            "runtime_registration",
            "backend",
            "operators",
            "warren",
        ]
        if key in manifest
    }
    return keep


def render_register_sql(manifest: dict[str, Any]) -> str:
    if manifest.get("kind") == "runtime_sidecar":
        registration = manifest["runtime_registration"]
        runtime = manifest.get("runtime") or {}
        endpoint_path = (
            manifest.get("warren", {}).get("endpoint_path")
            or registration.get("endpoint_path")
            or "/run"
        )
        service = manifest["name"].replace("_", "-")
        endpoint = registration.get("endpoint") or f"http://{service}:8080{endpoint_path}"
        labels = registration.get("labels") or {
            "language": runtime.get("language", "python"),
            "capability_kind": "runtime_sidecar",
        }
        return "\n".join(
            [
                "-- Generated by capabilities/tools/rvbbit-capability.",
                f"-- Runtime capability: {manifest['name']}",
                "SELECT rvbbit.register_python_runtime(",
                f"  runtime_name     => {sql_lit(registration['name'])},",
                f"  endpoint_url     => {sql_lit(endpoint)},",
                "  runtime_status  => 'ready',",
                f"  runtime_labels  => {sql_json(labels)},",
                "  runtime_source  => 'capability',",
                f"  install_manifest => {sql_json(install_manifest(manifest))},",
                f"  set_default     => {str(bool(registration.get('set_default', True))).lower()}",
                ");",
                "",
            ]
        )

    backend = manifest["backend"]
    source = manifest.get("source") or {}
    opts = dict(backend.get("opts") or {})
    if source.get("model") and "model" not in opts:
        opts["model"] = source["model"]
    if source.get("revision") and "revision" not in opts:
        opts["revision"] = source["revision"]

    args = {
        "backend_name": backend["name"],
        "backend_endpoint": backend_endpoint(manifest),
        "backend_transport": backend.get("transport", "rvbbit"),
        "backend_batch_size": int(backend.get("batch_size", 32)),
        "backend_max_concur": int(backend.get("max_concurrent", 4)),
        "backend_timeout_ms": int(backend.get("timeout_ms", 60000)),
        "backend_auth_env": backend.get("auth_env"),
        "backend_opts": opts,
        "backend_description": backend.get("description")
        or manifest.get("description")
        or manifest.get("title")
        or manifest["name"],
        "backend_source_provider": source.get("provider"),
        "backend_source_model": source.get("model"),
        "backend_source_revision": source.get("revision"),
        "backend_install_manifest": install_manifest(manifest),
    }

    return "\n".join(
        [
            "-- Generated by capabilities/tools/rvbbit-capability.",
            f"-- Capability: {manifest['name']}",
            "SELECT rvbbit.register_backend(",
            f"  backend_name             => {sql_lit(args['backend_name'])},",
            f"  backend_endpoint         => {sql_lit(args['backend_endpoint'])},",
            f"  backend_transport        => {sql_lit(args['backend_transport'])},",
            f"  backend_batch_size       => {args['backend_batch_size']},",
            f"  backend_max_concur       => {args['backend_max_concur']},",
            f"  backend_timeout_ms       => {args['backend_timeout_ms']},",
            f"  backend_auth_env         => {sql_lit(args['backend_auth_env'])},",
            f"  backend_opts             => {sql_json(args['backend_opts'])},",
            f"  backend_description      => {sql_lit(args['backend_description'])},",
            f"  backend_source_provider  => {sql_lit(args['backend_source_provider'])},",
            f"  backend_source_model     => {sql_lit(args['backend_source_model'])},",
            f"  backend_source_revision  => {sql_lit(args['backend_source_revision'])},",
            f"  backend_install_manifest => {sql_json(args['backend_install_manifest'])}",
            ");",
            "SELECT rvbbit.reload_backends();",
            "",
        ]
    )


def default_step(manifest: dict[str, Any], op: dict[str, Any]) -> dict[str, Any]:
    return {
        "name": op.get("step_name", manifest["backend"]["name"]),
        "kind": "specialist",
        "specialist": manifest["backend"]["name"],
        "inputs": op.get("inputs") or {name: f"{{{{ inputs.{name} }}}}" for name in op["arg_names"]},
    }


def render_operator_sql(manifest: dict[str, Any]) -> str:
    chunks: list[str] = [
        "-- Generated by capabilities/tools/rvbbit-capability.",
        f"-- Operators for capability: {manifest['name']}",
    ]
    for op in manifest.get("operators") or []:
        steps = op.get("steps") or [default_step(manifest, op)]
        arg_types = op.get("arg_types") or ["text" for _ in op["arg_names"]]
        chunks.extend(
            [
                "",
                "SELECT rvbbit.create_operator(",
                f"  op_name        => {sql_lit(op['name'])},",
                f"  op_arg_names   => {sql_text_array(op['arg_names'])},",
                f"  op_arg_types   => {sql_text_array(arg_types)},",
                f"  op_return_type => {sql_lit(op['return_type'])},",
                f"  op_parser      => {sql_lit(op.get('parser'))},",
                f"  op_shape       => {sql_lit(op.get('shape', 'scalar'))},",
                f"  op_description => {sql_lit(op.get('description') or manifest.get('description'))},",
                f"  op_tests       => {sql_json(op['tests']) if op.get('tests') else 'NULL'},",
                f"  op_steps       => {sql_json(steps)}",
                ");",
            ]
        )
    chunks.append("")
    return "\n".join(chunks)


def render_smoke_sql(manifest: dict[str, Any]) -> str:
    if manifest.get("kind") == "runtime_sidecar":
        name = manifest["runtime_registration"]["name"]
        return "\n".join(
            [
                "-- Generated runtime smoke check.",
                "SELECT name, endpoint_url, status",
                "FROM rvbbit.python_runtimes",
                f"WHERE name = {sql_lit(name)};",
                "",
            ]
        )

    lines = [
        "-- Generated smoke checks. Run after register.sql/operator.sql.",
        f"SELECT jsonb_pretty(rvbbit.backend_probe({sql_lit(manifest['backend']['name'])}));",
    ]
    smoke = manifest.get("smoke") or {}
    lines.extend(smoke.get("sql") or [])
    operators = manifest.get("operators") or []
    if operators and smoke.get("inputs"):
        first = smoke["inputs"][0]
        for op in operators:
            args = [first.get(name, "") for name in op["arg_names"]]
            arg_sql = ", ".join(sql_lit(value) for value in args)
            lines.append(f"SELECT rvbbit.{op['name']}({arg_sql});")
    lines.append("")
    return "\n".join(lines)


def render_compose(manifest: dict[str, Any]) -> str:
    service = manifest["name"].replace("_", "-")
    source = manifest.get("source") or {}
    runtime = manifest.get("runtime") or {}
    env = dict(runtime.get("env") or {})
    env.setdefault("RVBBIT_CAPABILITY_MODEL", source.get("model", ""))
    env.setdefault("RVBBIT_CAPABILITY_REVISION", source.get("revision", ""))
    env.setdefault("RVBBIT_CAPABILITY_HANDLER", runtime.get("handler", "custom"))
    env.setdefault("RVBBIT_CAPABILITY_DEVICE", runtime.get("device", "auto"))
    env_lines = "\n".join(f"      {key}: {json.dumps(value)}" for key, value in sorted(env.items()))
    volume_specs = runtime.get("volumes") or [{"name": "hf_cache", "mount": "/root/.cache/huggingface"}]
    volume_mounts = "\n".join(
        f"      - {spec['name']}:{spec['mount']}"
        for spec in volume_specs
        if spec.get("name") and spec.get("mount")
    )
    volume_defs = "\n".join(
        f"  {spec['name']}:"
        for spec in volume_specs
        if spec.get("name") and spec.get("mount")
    )
    return f"""services:
  {service}:
    build: .
    container_name: rvbbit-{service}
    ports:
      - "${{RVBBIT_CAPABILITY_PORT:-8080}}:8080"
    environment:
{env_lines}
    volumes:
{volume_mounts}
    networks:
      - rvbbit
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8080/health').read()"]
      interval: 10s
      timeout: 5s
      retries: 60

networks:
  rvbbit:
    name: ${{RVBBIT_DOCKER_NETWORK:-docker_default}}
    external: true

volumes:
{volume_defs}
"""


def render_gpu_compose(manifest: dict[str, Any]) -> str:
    service = manifest["name"].replace("_", "-")
    return f"""services:
  {service}:
    gpus: all
    environment:
      RVBBIT_CAPABILITY_DEVICE: "cuda"
"""


def render_all(manifest: dict[str, Any]) -> str:
    return render_register_sql(manifest) + "\n" + render_operator_sql(manifest) + "\n" + render_smoke_sql(manifest)


def render_deploy_sql(
    manifest: dict[str, Any],
    target_selector: dict[str, Any],
    job_name: str | None = None,
) -> str:
    return "\n".join(
        [
            "-- Queue capability deployment for a Warren agent.",
            "SELECT rvbbit.deploy_capability(",
            f"  capability_manifest => {sql_json(install_manifest(manifest))},",
            f"  target_selector     => {sql_json(target_selector)},",
            f"  job_name            => {sql_lit(job_name)}",
            ");",
            "",
        ]
    )


def replace_tokens(text: str, values: dict[str, str]) -> str:
    for key, value in values.items():
        text = text.replace("{{ " + key + " }}", value)
        text = text.replace("{{" + key + "}}", value)
    return text


def handler_requirements(handler: str) -> list[str]:
    if handler in {
        "embedding",
        "sequence_classification",
        "zero_shot_classification",
        "gliner",
    }:
        return [
            "transformers==4.46.3",
            "sentencepiece==0.2.0",
        ]
    if handler in {"tabular_classification", "tabular_regression"}:
        return [
            "huggingface_hub==0.26.5",
            "joblib==1.4.2",
            "numpy==2.1.3",
            "pandas==2.2.3",
            "scikit-learn==1.5.2",
        ]
    return []


def scaffold(manifest: dict[str, Any], out_dir: Path, force: bool = False) -> None:
    if out_dir.exists() and any(out_dir.iterdir()) and not force:
        raise SystemExit(f"{out_dir} exists and is not empty; pass --force to overwrite")
    out_dir.mkdir(parents=True, exist_ok=True)

    runtime = manifest.get("runtime") or {}
    source = manifest.get("source") or {}
    template = runtime.get("template", "hf-rvbbit-fastapi")
    template_dir = TEMPLATES / template
    if not template_dir.exists():
        raise SystemExit(f"template not found: {template}")

    base_image = runtime.get("base_image", "pytorch/pytorch:2.5.1-cuda12.4-cudnn9-runtime")
    values = {
        "base_image": base_image,
        "model": source.get("model", ""),
        "revision": source.get("revision", ""),
        "handler": runtime.get("handler", "custom"),
        "device": runtime.get("device", "auto"),
    }

    for path in template_dir.iterdir():
        if path.is_file():
            text = replace_tokens(path.read_text(), values)
            target = out_dir / path.name
            target.write_text(text)

    extra = handler_requirements(runtime.get("handler", "custom"))
    extra.extend(runtime.get("extra_requirements") or [])
    if extra:
        req_path = out_dir / "requirements.txt"
        existing = set(req_path.read_text().splitlines()) if req_path.exists() else set()
        with req_path.open("a") as fh:
            for req in extra:
                if req not in existing:
                    fh.write(f"\n{req}\n")
                    existing.add(req)

    manifest_path = out_dir / "rvbbit.backend.yaml"
    try:
        import yaml  # type: ignore

        manifest_path.write_text(yaml.safe_dump(manifest, sort_keys=False))
    except Exception:
        manifest_path.write_text(json.dumps(manifest, indent=2, sort_keys=True) + "\n")

    (out_dir / "register.sql").write_text(render_register_sql(manifest))
    (out_dir / "operator.sql").write_text(render_operator_sql(manifest))
    (out_dir / "smoke.sql").write_text(render_smoke_sql(manifest))
    (out_dir / "compose.yaml").write_text(render_compose(manifest))
    (out_dir / "compose.gpu.yaml").write_text(render_gpu_compose(manifest))
    (out_dir / "README.md").write_text(scaffold_readme(manifest))


def scaffold_readme(manifest: dict[str, Any]) -> str:
    service = manifest["name"].replace("_", "-")
    if manifest.get("kind") == "runtime_sidecar":
        endpoint_path = (
            manifest.get("warren", {}).get("endpoint_path")
            or (manifest.get("runtime_registration") or {}).get("endpoint_path")
            or "/run"
        )
        runtime_name = (manifest.get("runtime_registration") or {}).get("name", manifest["name"])
        return f"""# {manifest.get('title') or manifest['name']}

{manifest.get('description') or 'Generated Rvbbit runtime sidecar.'}

## Run

```bash
docker compose up -d --build
```

## Register In Rvbbit

```bash
psql "$RVBBIT_DSN" -f register.sql
psql "$RVBBIT_DSN" -f smoke.sql
```

The generated service joins `${{RVBBIT_DOCKER_NETWORK:-docker_default}}` so
the default endpoint `http://{service}:8080{endpoint_path}` is reachable from
the Rvbbit Postgres container. The runtime is registered as `{runtime_name}`.
Adjust `register.sql` if your database is outside Docker or the sidecar is
reachable at a different hostname.
"""
    return f"""# {manifest.get('title') or manifest['name']}

{manifest.get('description') or 'Generated Rvbbit capability sidecar.'}

## Run

```bash
docker compose up -d --build
```

With NVIDIA GPU access:

```bash
docker compose -f compose.yaml -f compose.gpu.yaml up -d --build
```

## Register In Rvbbit

```bash
psql "$RVBBIT_DSN" -f register.sql
psql "$RVBBIT_DSN" -f operator.sql
psql "$RVBBIT_DSN" -f smoke.sql
```

The generated service joins `${{RVBBIT_DOCKER_NETWORK:-docker_default}}` so
the default endpoint `http://{service}:8080/predict` is reachable from the
Rvbbit Postgres container. Adjust `register.sql` if your database is outside
Docker or the sidecar is reachable at a different hostname.
"""


def manifest_relpath(path: Path, root: Path) -> str:
    try:
        return str(path.resolve().relative_to(root.resolve()))
    except ValueError:
        return str(path)


def catalog_entry(path: Path, root: Path, manifest: dict[str, Any]) -> dict[str, Any]:
    rel = manifest_relpath(path, root).replace("\\", "/")
    default_root = (ROOT / "manifests").resolve()
    manifest_path = (
        f"capabilities/manifests/{rel}"
        if root.resolve() == default_root
        else rel
    )
    source = manifest.get("source") or {}
    runtime = manifest.get("runtime") or {}
    backend = manifest.get("backend") or {}
    operators = manifest.get("operators") or []
    return {
        "id": rel,
        "name": manifest["name"],
        "title": manifest.get("title") or manifest["name"],
        "description": manifest.get("description"),
        "tags": manifest.get("tags") or [],
        "kind": manifest.get("kind"),
        "source_provider": source.get("provider"),
        "source_model": source.get("model"),
        "source_revision": source.get("revision"),
        "license": manifest.get("license"),
        "backend_name": backend.get("name"),
        "backend_transport": backend.get("transport", "rvbbit"),
        "runtime_name": (manifest.get("runtime_registration") or {}).get("name"),
        "runtime_language": (manifest.get("runtime_registration") or {}).get("language")
        or runtime.get("language"),
        "runtime_template": runtime.get("template", "hf-rvbbit-fastapi"),
        "runtime_handler": runtime.get("handler", "custom"),
        "endpoint_path": (manifest.get("warren") or {}).get("endpoint_path")
        or (manifest.get("runtime_registration") or {}).get("endpoint_path"),
        "device": runtime.get("device", "auto"),
        "operators": [op.get("name") for op in operators if op.get("name")],
        "manifest_path": manifest_path,
    }


def load_catalog(root: Path) -> list[dict[str, Any]]:
    entries: list[dict[str, Any]] = []
    for path in sorted(root.rglob("*.yaml")) + sorted(root.rglob("*.json")):
        try:
            manifest = load_manifest(path)
        except SystemExit:
            continue
        entries.append(catalog_entry(path, root, manifest))
    return entries


def catalog_doc(root: Path, include_timestamp: bool = False) -> dict[str, Any]:
    doc: dict[str, Any] = {
        "schema_version": 1,
        "capabilities": load_catalog(root),
    }
    if include_timestamp:
        from datetime import datetime, timezone

        doc["generated_at"] = datetime.now(timezone.utc).isoformat()
    return doc


def matches_entry(entry: dict[str, Any], terms: list[str]) -> bool:
    haystack = json.dumps(entry, sort_keys=True).lower()
    return all(term.lower() in haystack for term in terms)


def run_command(cmd: list[str], cwd: Path | None = None) -> None:
    print("+ " + " ".join(cmd), file=sys.stderr)
    subprocess.run(cmd, cwd=str(cwd) if cwd else None, check=True)


def psql_apply(dsn: str, sql_file: Path) -> None:
    run_command(["psql", dsn, "-v", "ON_ERROR_STOP=1", "-f", str(sql_file)])


def psql_scalar(dsn: str, sql: str) -> str:
    print("+ psql <deploy-sql>", file=sys.stderr)
    result = subprocess.run(
        ["psql", dsn, "-v", "ON_ERROR_STOP=1", "-At", "-c", sql],
        check=True,
        text=True,
        stdout=subprocess.PIPE,
    )
    return result.stdout.strip()


def cmd_render(args: argparse.Namespace) -> None:
    manifest = load_manifest(Path(args.manifest))
    if args.part == "register":
        print(render_register_sql(manifest), end="")
    elif args.part == "operators":
        print(render_operator_sql(manifest), end="")
    elif args.part == "smoke":
        print(render_smoke_sql(manifest), end="")
    elif args.part == "compose":
        print(render_compose(manifest), end="")
    elif args.part == "compose-gpu":
        print(render_gpu_compose(manifest), end="")
    elif args.part == "deploy":
        target = json.loads(args.target)
        if not isinstance(target, dict):
            raise SystemExit("--target must be a JSON object")
        print(render_deploy_sql(manifest, target, args.job_name), end="")
    else:
        print(render_all(manifest), end="")


def cmd_scaffold(args: argparse.Namespace) -> None:
    manifest = load_manifest(Path(args.manifest))
    scaffold(manifest, Path(args.out_dir), force=args.force)
    print(f"wrote {args.out_dir}")


def cmd_list(args: argparse.Namespace) -> None:
    root = Path(args.root)
    for entry in load_catalog(root):
        capability_name = entry.get("backend_name") or entry.get("runtime_name") or ""
        print(
            f"{entry['id']}\t{capability_name}\t{entry['source_model'] or ''}\t{entry['title']}"
        )


def cmd_catalog_build(args: argparse.Namespace) -> None:
    doc = catalog_doc(Path(args.root), include_timestamp=args.timestamp)
    text = json.dumps(doc, indent=2, sort_keys=True) + "\n"
    if args.output:
        Path(args.output).write_text(text)
    else:
        print(text, end="")


def cmd_catalog_search(args: argparse.Namespace) -> None:
    entries = load_catalog(Path(args.root))
    terms = args.terms
    for entry in entries:
        if terms and not matches_entry(entry, terms):
            continue
        tags = ",".join(entry.get("tags") or [])
        capability_name = entry.get("backend_name") or entry.get("runtime_name") or ""
        print(
            f"{entry['id']}\t{capability_name}\t{entry['source_model'] or ''}\t{tags}\t{entry['title']}"
        )


def cmd_install(args: argparse.Namespace) -> None:
    manifest_path = Path(args.manifest)
    manifest = load_manifest(manifest_path)
    out_dir = Path(args.out_dir or Path(".rvbbit") / "capabilities" / manifest["name"])
    scaffold(manifest, out_dir, force=args.force)
    print(f"wrote {out_dir}")

    if not args.no_compose:
        compose_cmd = ["docker", "compose", "-f", "compose.yaml"]
        if args.gpu:
            compose_cmd.extend(["-f", "compose.gpu.yaml"])
        compose_cmd.extend(["up", "-d", "--build"])
        run_command(compose_cmd, cwd=out_dir)

    if args.no_sql:
        return

    dsn = args.dsn or os.environ.get("RVBBIT_DSN")
    if not dsn:
        raise SystemExit("set --dsn or RVBBIT_DSN, or pass --no-sql")
    psql_apply(dsn, out_dir / "register.sql")
    psql_apply(dsn, out_dir / "operator.sql")
    if not args.no_smoke:
        psql_apply(dsn, out_dir / "smoke.sql")


def cmd_deploy(args: argparse.Namespace) -> None:
    manifest = load_manifest(Path(args.manifest))
    try:
        target = json.loads(args.target)
    except json.JSONDecodeError as exc:
        raise SystemExit(f"--target must be JSON: {exc}") from exc
    if not isinstance(target, dict):
        raise SystemExit("--target must be a JSON object")

    sql = render_deploy_sql(manifest, target, args.job_name)
    if args.print_sql:
        print(sql, end="")
        return

    dsn = args.dsn or os.environ.get("RVBBIT_DSN")
    if not dsn:
        raise SystemExit("set --dsn or RVBBIT_DSN, or pass --print-sql")
    job_id = psql_scalar(dsn, sql)
    print(job_id)


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="rvbbit-capability")
    sub = parser.add_subparsers(required=True)

    p_render = sub.add_parser("render", help="render SQL/config from a manifest")
    p_render.add_argument("manifest")
    p_render.add_argument(
        "--part",
        choices=[
            "all",
            "register",
            "operators",
            "smoke",
            "compose",
            "compose-gpu",
            "deploy",
        ],
        default="all",
    )
    p_render.add_argument("--target", default="{}")
    p_render.add_argument("--job-name")
    p_render.set_defaults(func=cmd_render)

    p_scaffold = sub.add_parser("scaffold", help="write a runnable sidecar bundle")
    p_scaffold.add_argument("manifest")
    p_scaffold.add_argument("out_dir")
    p_scaffold.add_argument("--force", action="store_true")
    p_scaffold.set_defaults(func=cmd_scaffold)

    p_install = sub.add_parser("install", help="scaffold, optionally run compose, and apply SQL")
    p_install.add_argument("manifest")
    p_install.add_argument("--out-dir")
    p_install.add_argument("--dsn")
    p_install.add_argument("--force", action="store_true")
    p_install.add_argument("--gpu", action="store_true")
    p_install.add_argument("--no-compose", action="store_true")
    p_install.add_argument("--no-sql", action="store_true")
    p_install.add_argument("--no-smoke", action="store_true")
    p_install.set_defaults(func=cmd_install)

    p_deploy = sub.add_parser("deploy", help="queue a capability deployment for Warren")
    p_deploy.add_argument("manifest")
    p_deploy.add_argument("--dsn")
    p_deploy.add_argument("--target", default="{}")
    p_deploy.add_argument("--job-name")
    p_deploy.add_argument("--print-sql", action="store_true")
    p_deploy.set_defaults(func=cmd_deploy)

    p_list = sub.add_parser("list", help="list curated manifests")
    p_list.add_argument("--root", default=str(ROOT / "manifests"))
    p_list.set_defaults(func=cmd_list)

    p_catalog = sub.add_parser("catalog", help="build or search a capability catalog")
    catalog_sub = p_catalog.add_subparsers(required=True)

    p_catalog_build = catalog_sub.add_parser("build", help="build catalog JSON")
    p_catalog_build.add_argument("--root", default=str(ROOT / "manifests"))
    p_catalog_build.add_argument("--output", "-o")
    p_catalog_build.add_argument("--timestamp", action="store_true")
    p_catalog_build.set_defaults(func=cmd_catalog_build)

    p_catalog_search = catalog_sub.add_parser("search", help="search curated manifests")
    p_catalog_search.add_argument("terms", nargs="*")
    p_catalog_search.add_argument("--root", default=str(ROOT / "manifests"))
    p_catalog_search.set_defaults(func=cmd_catalog_search)

    args = parser.parse_args(argv)
    args.func(args)
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
