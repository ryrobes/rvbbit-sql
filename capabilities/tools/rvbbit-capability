#!/usr/bin/env python3
"""Render and scaffold Rvbbit capability packs and manifests.

The tool is intentionally dependency-light. YAML pack/manifests require PyYAML;
JSON pack/manifests work with the Python standard library.
"""
from __future__ import annotations

import argparse
import copy
import datetime as dt
import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[1]
REPO_ROOT = ROOT.parent
PACKS = ROOT / "packs"
TEMPLATES = ROOT / "templates"
PACK_MANIFEST_NAMES = ("rvbbit-pack.yaml", "rvbbit-pack.json")
CAPABILITY_MANIFEST_NAMES = (
    "capability.yaml",
    "capability.json",
    "rvbbit.backend.yaml",
    "rvbbit.backend.json",
)


def load_doc(path: Path) -> dict[str, Any]:
    text = path.read_text()
    if path.suffix.lower() == ".json":
        data = json.loads(text)
    else:
        try:
            import yaml  # type: ignore
        except Exception as exc:  # pragma: no cover - depends on local env
            raise SystemExit(
                "YAML manifests require PyYAML. Use a .json manifest or install pyyaml."
            ) from exc
        data = yaml.safe_load(text)
    if not isinstance(data, dict):
        raise SystemExit(f"{path}: manifest must be an object")
    return data


def load_manifest(path: Path) -> dict[str, Any]:
    manifest_path = resolve_manifest_path(path)
    data = load_doc(manifest_path)
    validate_manifest(data, manifest_path)
    return data


def load_pack_metadata(path: Path) -> dict[str, Any]:
    data = load_doc(path)
    validate_pack_metadata(data, path)
    return data


def load_pack_and_manifest(path: Path) -> tuple[Path | None, dict[str, Any], Path, dict[str, Any]]:
    pack_path = find_pack_manifest(path)
    if pack_path:
        pack = load_pack_metadata(pack_path)
        manifest_path = pack_capability_path(pack_path, pack)
        manifest = load_manifest(manifest_path)
        return pack_path, pack, manifest_path, manifest
    manifest_path = resolve_manifest_path(path)
    return None, {}, manifest_path, load_manifest(manifest_path)


def validate_pack_metadata(pack: dict[str, Any], path: Path) -> None:
    required = ["api_version", "id", "name", "capability"]
    missing = [key for key in required if key not in pack]
    if missing:
        raise SystemExit(f"{path}: missing required pack field(s): {', '.join(missing)}")
    if pack["api_version"] != "rvbbit.pack/v1":
        raise SystemExit(f"{path}: unsupported pack api_version {pack['api_version']!r}")
    if not str(pack["id"]).strip():
        raise SystemExit(f"{path}: pack id cannot be empty")
    if not str(pack["capability"]).strip():
        raise SystemExit(f"{path}: capability path cannot be empty")


def find_pack_manifest(path: Path) -> Path | None:
    if path.is_file() and path.name in PACK_MANIFEST_NAMES:
        return path
    if path.is_dir():
        for name in PACK_MANIFEST_NAMES:
            candidate = path / name
            if candidate.exists():
                return candidate
    return None


def pack_capability_path(pack_path: Path, pack: dict[str, Any]) -> Path:
    capability = Path(str(pack.get("capability") or "capability.yaml"))
    if capability.is_absolute():
        return capability
    return pack_path.parent / capability


def resolve_manifest_path(path: Path) -> Path:
    pack_path = find_pack_manifest(path)
    if pack_path:
        pack = load_pack_metadata(pack_path)
        return pack_capability_path(pack_path, pack)
    if path.is_dir():
        for name in CAPABILITY_MANIFEST_NAMES:
            candidate = path / name
            if candidate.exists():
                return candidate
    return path


def validate_manifest(manifest: dict[str, Any], path: Path) -> None:
    required = ["api_version", "kind", "name"]
    missing = [key for key in required if key not in manifest]
    if missing:
        raise SystemExit(f"{path}: missing required field(s): {', '.join(missing)}")
    if manifest["api_version"] != "rvbbit.capability/v1":
        raise SystemExit(f"{path}: unsupported api_version {manifest['api_version']!r}")
    if manifest["kind"] not in {"hf_backend", "runtime_sidecar", "llm_provider"}:
        raise SystemExit(f"{path}: unsupported kind {manifest['kind']!r}")
    if manifest["kind"] in {"hf_backend", "llm_provider"}:
        backend = manifest.get("backend")
        if not isinstance(backend, dict) or not backend.get("name"):
            raise SystemExit(f"{path}: backend.name is required")
    if manifest["kind"] == "llm_provider":
        registration = manifest.get("provider_registration")
        if not isinstance(registration, dict):
            raise SystemExit(f"{path}: provider_registration is required")
        for key in ["provider", "model"]:
            if not registration.get(key):
                raise SystemExit(f"{path}: provider_registration.{key} is required")
    if manifest["kind"] == "runtime_sidecar":
        runtime = manifest.get("runtime")
        if not isinstance(runtime, dict) or not runtime.get("language"):
            raise SystemExit(f"{path}: runtime.language is required")
        registration = manifest.get("runtime_registration")
        if not isinstance(registration, dict) or not registration.get("name"):
            raise SystemExit(f"{path}: runtime_registration.name is required")
    operators = manifest.get("operators") or []
    if not isinstance(operators, list):
        raise SystemExit(f"{path}: operators must be a list")
    for op in operators:
        if not isinstance(op, dict):
            raise SystemExit(f"{path}: each operator must be an object")
        for key in ["name", "arg_names", "return_type"]:
            if key not in op:
                raise SystemExit(f"{path}: operator missing {key}")
        if op.get("arg_types") and len(op["arg_types"]) != len(op["arg_names"]):
            raise SystemExit(f"{path}: operator {op['name']} arg_types length mismatch")


def sql_lit(value: Any) -> str:
    if value is None:
        return "NULL"
    return "'" + str(value).replace("'", "''") + "'"


def sql_json(value: Any) -> str:
    return sql_lit(json.dumps(value, sort_keys=True, separators=(",", ":"))) + "::jsonb"


def sql_text_array(values: list[str]) -> str:
    inner = ",".join(sql_lit(value) for value in values)
    return f"ARRAY[{inner}]"


def backend_endpoint(manifest: dict[str, Any]) -> str:
    backend = manifest["backend"]
    if backend.get("endpoint"):
        return backend["endpoint"]
    service = manifest["name"].replace("_", "-")
    endpoint_path = (manifest.get("warren") or {}).get("endpoint_path")
    if not endpoint_path:
        endpoint_path = "/v1/chat/completions" if manifest.get("kind") == "llm_provider" else "/predict"
    endpoint_path = endpoint_path if str(endpoint_path).startswith("/") else f"/{endpoint_path}"
    return f"http://{service}:8080{endpoint_path}"


def runtime_container_port(manifest: dict[str, Any]) -> int:
    runtime = manifest.get("runtime") or {}
    warren = manifest.get("warren") or {}
    return int(warren.get("container_port") or runtime.get("port") or 8080)


def runtime_health_path(manifest: dict[str, Any]) -> str:
    runtime = manifest.get("runtime") or {}
    warren = manifest.get("warren") or {}
    path = warren.get("health_path") or runtime.get("health_path") or "/health"
    return path if str(path).startswith("/") else f"/{path}"


def runtime_endpoint_path(manifest: dict[str, Any]) -> str:
    registration = manifest.get("runtime_registration") or {}
    path = (manifest.get("warren") or {}).get("endpoint_path") or registration.get("endpoint_path") or "/run"
    return path if str(path).startswith("/") else f"/{path}"


def install_manifest(
    manifest: dict[str, Any],
    resources: dict[str, Any] | None = None,
) -> dict[str, Any]:
    keep = {
        key: manifest[key]
        for key in [
            "api_version",
            "kind",
            "name",
            "title",
            "description",
            "license",
            "tags",
            "source",
            "runtime",
            "runtime_registration",
            "backend",
            "operators",
            "provider_registration",
            "warren",
            "resources",
            "system_runtime",
            "capability_role",
            "smoke",
        ]
        if key in manifest
    }
    if resources and "resources" not in keep:
        keep["resources"] = resources
    return keep


def render_register_sql(manifest: dict[str, Any]) -> str:
    if manifest.get("kind") == "runtime_sidecar":
        registration = manifest["runtime_registration"]
        runtime = manifest.get("runtime") or {}
        language = registration.get("language") or runtime.get("language") or "python"
        endpoint_path = runtime_endpoint_path(manifest)
        service = manifest["name"].replace("_", "-")
        port = runtime_container_port(manifest)
        endpoint = registration.get("endpoint") or f"http://{service}:{port}{endpoint_path}"
        labels = registration.get("labels") or {
            "language": language,
            "capability_kind": "runtime_sidecar",
        }
        register_fn = (
            "rvbbit.register_mcp_gateway"
            if language in {"mcp", "mcp_gateway"}
            else "rvbbit.register_python_runtime"
        )
        name_arg = "gateway_name" if language in {"mcp", "mcp_gateway"} else "runtime_name"
        status_arg = "gateway_status" if language in {"mcp", "mcp_gateway"} else "runtime_status"
        labels_arg = "gateway_labels" if language in {"mcp", "mcp_gateway"} else "runtime_labels"
        source_arg = "gateway_source" if language in {"mcp", "mcp_gateway"} else "runtime_source"
        return "\n".join(
            [
                "-- Generated by capabilities/tools/rvbbit-capability.",
                f"-- Runtime capability: {manifest['name']}",
                f"SELECT {register_fn}(",
                f"  {name_arg:<16} => {sql_lit(registration['name'])},",
                f"  endpoint_url     => {sql_lit(endpoint)},",
                f"  {status_arg:<16} => 'ready',",
                f"  {labels_arg:<16} => {sql_json(labels)},",
                f"  {source_arg:<16} => 'capability',",
                f"  install_manifest => {sql_json(install_manifest(manifest))},",
                f"  set_default     => {str(bool(registration.get('set_default', True))).lower()}",
                ");",
                "",
            ]
        )

    backend = manifest["backend"]
    source = manifest.get("source") or {}
    opts = dict(backend.get("opts") or {})
    if source.get("model") and "model" not in opts:
        opts["model"] = source["model"]
    if source.get("revision") and "revision" not in opts:
        opts["revision"] = source["revision"]

    args = {
        "backend_name": backend["name"],
        "backend_endpoint": backend_endpoint(manifest),
        "backend_transport": backend.get("transport", "rvbbit"),
        "backend_batch_size": int(backend.get("batch_size", 32)),
        "backend_max_concur": int(backend.get("max_concurrent", 4)),
        "backend_timeout_ms": int(backend.get("timeout_ms", 60000)),
        "backend_auth_env": backend.get("auth_env"),
        "backend_opts": opts,
        "backend_description": backend.get("description")
        or manifest.get("description")
        or manifest.get("title")
        or manifest["name"],
        "backend_source_provider": source.get("provider"),
        "backend_source_model": source.get("model"),
        "backend_source_revision": source.get("revision"),
        "backend_install_manifest": install_manifest(manifest),
    }

    lines = [
        "-- Generated by capabilities/tools/rvbbit-capability.",
        f"-- Capability: {manifest['name']}",
        "SELECT rvbbit.register_backend(",
        f"  backend_name             => {sql_lit(args['backend_name'])},",
        f"  backend_endpoint         => {sql_lit(args['backend_endpoint'])},",
        f"  backend_transport        => {sql_lit(args['backend_transport'])},",
        f"  backend_batch_size       => {args['backend_batch_size']},",
        f"  backend_max_concur       => {args['backend_max_concur']},",
        f"  backend_timeout_ms       => {args['backend_timeout_ms']},",
        f"  backend_auth_env         => {sql_lit(args['backend_auth_env'])},",
        f"  backend_opts             => {sql_json(args['backend_opts'])},",
        f"  backend_description      => {sql_lit(args['backend_description'])},",
        f"  backend_source_provider  => {sql_lit(args['backend_source_provider'])},",
        f"  backend_source_model     => {sql_lit(args['backend_source_model'])},",
        f"  backend_source_revision  => {sql_lit(args['backend_source_revision'])},",
        f"  backend_install_manifest => {sql_json(args['backend_install_manifest'])}",
        ");",
    ]

    if manifest.get("kind") == "llm_provider":
        registration = manifest.get("provider_registration") or {}
        provider = registration.get("provider")
        model = registration.get("model") or source.get("model")
        backend_name = registration.get("backend_name") or backend["name"]
        capabilities = registration.get("capabilities") or ["chat"]
        raw = dict(registration.get("raw") or {})
        raw.setdefault("capability", manifest.get("name"))
        raw.setdefault("source_model", source.get("model"))
        raw.setdefault("source_url", source.get("url"))
        lines.extend(
            [
                "SELECT rvbbit.register_self_hosted_model(",
                f"  provider           => {sql_lit(provider)},",
                f"  model              => {sql_lit(model)},",
                f"  backend_name       => {sql_lit(backend_name)},",
                f"  display_name       => {sql_lit(registration.get('display_name'))},",
                f"  family             => {sql_lit(registration.get('family'))},",
                f"  capabilities       => {sql_json(capabilities)},",
                f"  context_window     => {sql_lit(registration.get('context_window'))},",
                f"  output_token_limit => {sql_lit(registration.get('output_token_limit'))},",
                f"  input_per_mtok     => {sql_lit(registration.get('input_per_mtok'))},",
                f"  output_per_mtok    => {sql_lit(registration.get('output_per_mtok'))},",
                f"  currency           => {sql_lit(registration.get('currency', 'USD'))},",
                f"  cost_policy        => {sql_lit(registration.get('cost_policy', 'free'))},",
                f"  raw                => {sql_json(raw)}",
                ");",
            ]
        )
        if registration.get("set_default") is True:
            lines.append(f"SELECT rvbbit.set_default_provider({sql_lit(backend_name)});")

    lines.extend(["SELECT rvbbit.reload_backends();", ""])
    return "\n".join(lines)


def default_step(manifest: dict[str, Any], op: dict[str, Any]) -> dict[str, Any]:
    return {
        "name": op.get("step_name", manifest["backend"]["name"]),
        "kind": "specialist",
        "specialist": manifest["backend"]["name"],
        "inputs": op.get("inputs") or {name: f"{{{{ inputs.{name} }}}}" for name in op["arg_names"]},
    }


def render_operator_sql(manifest: dict[str, Any]) -> str:
    chunks: list[str] = [
        "-- Generated by capabilities/tools/rvbbit-capability.",
        f"-- Operators for capability: {manifest['name']}",
    ]
    for op in manifest.get("operators") or []:
        steps = op.get("steps") or [default_step(manifest, op)]
        arg_types = op.get("arg_types") or ["text" for _ in op["arg_names"]]
        infix_symbol_sql = sql_lit(op.get("infix_symbol"))
        if op.get("infix_symbol") and len(arg_types) == 2:
            infix_symbol_sql = (
                "(CASE WHEN EXISTS ("
                "SELECT 1 FROM pg_operator op "
                "WHERE op.oprnamespace = 'rvbbit'::regnamespace "
                f"AND op.oprname = {sql_lit(op['infix_symbol'])} "
                f"AND op.oprleft = {sql_lit(arg_types[0])}::regtype "
                f"AND op.oprright = {sql_lit(arg_types[1])}::regtype"
                f") THEN NULL ELSE {sql_lit(op['infix_symbol'])} END)"
            )
        chunks.extend(
            [
                "",
                "SELECT rvbbit.create_operator(",
                f"  op_name        => {sql_lit(op['name'])},",
                f"  op_arg_names   => {sql_text_array(op['arg_names'])},",
                f"  op_arg_types   => {sql_text_array(arg_types)},",
                f"  op_return_type => {sql_lit(op['return_type'])},",
                f"  op_parser      => {sql_lit(op.get('parser'))},",
                f"  op_shape       => {sql_lit(op.get('shape', 'scalar'))},",
                f"  op_description => {sql_lit(op.get('description') or manifest.get('description'))},",
                f"  op_infix_symbol => {infix_symbol_sql},",
                f"  op_infix_word   => {sql_lit(op.get('infix_word'))},",
                f"  op_tests       => {sql_json(op['tests']) if op.get('tests') else 'NULL'},",
                f"  op_steps       => {sql_json(steps)}",
                ");",
            ]
        )
        if op.get("infix_symbol") and len(arg_types) == 2:
            chunks.extend(
                [
                    "UPDATE rvbbit.operators",
                    f"SET infix_symbol = {sql_lit(op.get('infix_symbol'))},",
                    f"    infix_word = {sql_lit(op.get('infix_word'))}",
                    f"WHERE name = {sql_lit(op['name'])};",
                ]
            )
    chunks.append("")
    return "\n".join(chunks)


def render_smoke_sql(manifest: dict[str, Any]) -> str:
    if manifest.get("kind") == "runtime_sidecar":
        name = manifest["runtime_registration"]["name"]
        return "\n".join(
            [
                "-- Generated runtime smoke check.",
                "SELECT name, endpoint_url, status",
                "FROM rvbbit.python_runtimes",
                f"WHERE name = {sql_lit(name)};",
                "",
            ]
        )

    lines = [
        "-- Generated smoke checks. Run after register.sql/operator.sql.",
        f"SELECT jsonb_pretty(rvbbit.backend_probe({sql_lit(manifest['backend']['name'])}));",
    ]
    smoke = manifest.get("smoke") or {}
    lines.extend(smoke.get("sql") or [])
    operators = manifest.get("operators") or []
    if operators and smoke.get("inputs"):
        first = smoke["inputs"][0]
        for op in operators:
            args = [first.get(name, "") for name in op["arg_names"]]
            arg_sql = ", ".join(sql_lit(value) for value in args)
            lines.append(f"SELECT rvbbit.{op['name']}({arg_sql});")
    lines.append("")
    return "\n".join(lines)


def render_compose(manifest: dict[str, Any]) -> str:
    service = manifest["name"].replace("_", "-")
    source = manifest.get("source") or {}
    runtime = manifest.get("runtime") or {}
    container_port = runtime_container_port(manifest)
    health_path = runtime_health_path(manifest)
    env = dict(runtime.get("env") or {})
    env.setdefault("RVBBIT_CAPABILITY_MODEL", source.get("model", ""))
    env.setdefault("RVBBIT_CAPABILITY_REVISION", source.get("revision", ""))
    env.setdefault("RVBBIT_CAPABILITY_HANDLER", runtime.get("handler", "custom"))
    env.setdefault("RVBBIT_CAPABILITY_DEVICE", runtime.get("device", "auto"))
    env_lines = "\n".join(f"      {key}: {json.dumps(value)}" for key, value in sorted(env.items()))
    volume_specs = runtime.get("volumes") or [{"name": "hf_cache", "mount": "/root/.cache/huggingface"}]
    volume_mounts = "\n".join(
        f"      - {spec['name']}:{spec['mount']}"
        for spec in volume_specs
        if spec.get("name") and spec.get("mount")
    )
    volume_defs = "\n".join(
        f"  {spec['name']}:"
        for spec in volume_specs
        if spec.get("name") and spec.get("mount")
    )
    runtime_source = render_runtime_source(runtime)
    runtime_command = render_runtime_command(runtime)
    runtime_ipc = render_runtime_ipc(runtime)
    return f"""services:
  {service}:
{runtime_source}{runtime_command}{runtime_ipc}    container_name: rvbbit-{service}
    expose:
      - "{container_port}"
    environment:
{env_lines}
    volumes:
{volume_mounts}
    networks:
      - rvbbit
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:{container_port}{health_path}').read()"]
      interval: 10s
      timeout: 5s
      retries: 60

networks:
  rvbbit:
    name: ${{RVBBIT_DOCKER_NETWORK:-docker_default}}
    external: true

volumes:
{volume_defs}
"""


def render_host_ports_compose(manifest: dict[str, Any]) -> str:
    service = manifest["name"].replace("_", "-")
    container_port = runtime_container_port(manifest)
    return f"""services:
  {service}:
    ports:
      - "${{RVBBIT_CAPABILITY_PORT:-0}}:{container_port}"
"""


def runtime_image(runtime: dict[str, Any]) -> str | None:
    image = str(runtime.get("image") or "").strip()
    if not image:
        return None
    digest = str(runtime.get("image_digest") or "").strip()
    if digest and "@" not in image:
        return f"{image}@{digest}"
    return image


def render_runtime_source(runtime: dict[str, Any]) -> str:
    image = runtime_image(runtime)
    if image:
        pull_policy = runtime.get("pull_policy") or "missing"
        return f"    image: {json.dumps(image)}\n    pull_policy: {json.dumps(pull_policy)}\n"
    return "    build: .\n"


def runtime_argv(runtime: dict[str, Any]) -> list[str]:
    argv: list[str] = []
    command = runtime.get("command")
    if isinstance(command, list):
        argv.extend(str(item) for item in command)
    elif command not in {None, ""}:
        argv.append(str(command))
    args = runtime.get("args")
    if isinstance(args, list):
        argv.extend(str(item) for item in args)
    elif args not in {None, ""}:
        argv.append(str(args))
    return argv


def render_runtime_command(runtime: dict[str, Any]) -> str:
    argv = runtime_argv(runtime)
    if not argv:
        return ""
    lines = ["    command:"]
    lines.extend(f"      - {json.dumps(arg)}" for arg in argv)
    return "\n".join(lines) + "\n"


def render_runtime_ipc(runtime: dict[str, Any]) -> str:
    ipc = runtime.get("ipc")
    if not ipc:
        return ""
    return f"    ipc: {json.dumps(str(ipc))}\n"


def render_gpu_compose(manifest: dict[str, Any]) -> str:
    service = manifest["name"].replace("_", "-")
    return f"""services:
  {service}:
    gpus: all
    environment:
      RVBBIT_CAPABILITY_DEVICE: "cuda"
"""


def render_all(manifest: dict[str, Any]) -> str:
    return render_register_sql(manifest) + "\n" + render_operator_sql(manifest) + "\n" + render_smoke_sql(manifest)


def render_deploy_sql(
    manifest: dict[str, Any],
    target_selector: dict[str, Any],
    job_name: str | None = None,
) -> str:
    return "\n".join(
        [
            "-- Queue capability deployment for a Warren agent.",
            "SELECT rvbbit.deploy_capability(",
            f"  capability_manifest => {sql_json(install_manifest(manifest))},",
            f"  target_selector     => {sql_json(target_selector)},",
            f"  job_name            => {sql_lit(job_name)}",
            ");",
            "",
        ]
    )


def replace_tokens(text: str, values: dict[str, str]) -> str:
    for key, value in values.items():
        text = text.replace("{{ " + key + " }}", value)
        text = text.replace("{{" + key + "}}", value)
    return text


def handler_requirements(handler: str) -> list[str]:
    if handler in {
        "embedding",
        "sequence_classification",
        "question_answering",
        "summarization",
        "token_classification",
        "table_question_answering",
        "zero_shot_classification",
        "gliner",
    }:
        requirements = [
            "transformers==4.46.3",
            "sentencepiece==0.2.0",
        ]
        if handler == "gliner":
            requirements.append("gliner==0.2.16")
        if handler == "table_question_answering":
            requirements.append("pandas==2.2.3")
        return requirements
    if handler in {"tabular_classification", "tabular_regression", "tabular_foundation"}:
        return [
            "huggingface_hub==0.26.5",
            "joblib==1.4.2",
            "numpy==2.1.3",
            "pandas==2.2.3",
            "scikit-learn==1.5.2",
        ]
    return []


def scaffold(manifest: dict[str, Any], out_dir: Path, force: bool = False) -> None:
    if out_dir.exists() and any(out_dir.iterdir()) and not force:
        raise SystemExit(f"{out_dir} exists and is not empty; pass --force to overwrite")
    out_dir.mkdir(parents=True, exist_ok=True)

    runtime = manifest.get("runtime") or {}
    source = manifest.get("source") or {}
    if not runtime_image(runtime):
        template = runtime.get("template", "hf-rvbbit-fastapi")
        template_dir = TEMPLATES / template
        if not template_dir.exists():
            raise SystemExit(f"template not found: {template}")

        base_image = runtime.get("base_image", "pytorch/pytorch:2.5.1-cuda12.4-cudnn9-runtime")
        values = {
            "base_image": base_image,
            "model": source.get("model", ""),
            "revision": source.get("revision", ""),
            "handler": runtime.get("handler", "custom"),
            "device": runtime.get("device", "auto"),
        }

        for path in template_dir.rglob("*"):
            if path.is_dir():
                continue
            if "__pycache__" in path.parts or path.suffix in {".pyc", ".pyo"}:
                continue
            rel = path.relative_to(template_dir)
            target = out_dir / rel
            target.parent.mkdir(parents=True, exist_ok=True)
            try:
                text = replace_tokens(path.read_text(), values)
            except UnicodeDecodeError:
                shutil.copy2(path, target)
            else:
                target.write_text(text)

        extra = handler_requirements(runtime.get("handler", "custom"))
        extra.extend(runtime.get("extra_requirements") or [])
        if extra:
            req_path = out_dir / "requirements.txt"
            existing = set(req_path.read_text().splitlines()) if req_path.exists() else set()
            with req_path.open("a") as fh:
                for req in extra:
                    if req not in existing:
                        fh.write(f"\n{req}\n")
                        existing.add(req)

    manifest_path = out_dir / "rvbbit.backend.yaml"
    try:
        import yaml  # type: ignore

        manifest_path.write_text(yaml.safe_dump(manifest, sort_keys=False))
    except Exception:
        manifest_path.write_text(json.dumps(manifest, indent=2, sort_keys=True) + "\n")

    (out_dir / "register.sql").write_text(render_register_sql(manifest))
    (out_dir / "operator.sql").write_text(render_operator_sql(manifest))
    (out_dir / "smoke.sql").write_text(render_smoke_sql(manifest))
    (out_dir / "compose.yaml").write_text(render_compose(manifest))
    (out_dir / "compose.host-ports.yaml").write_text(render_host_ports_compose(manifest))
    (out_dir / "compose.gpu.yaml").write_text(render_gpu_compose(manifest))
    (out_dir / "README.md").write_text(scaffold_readme(manifest))


