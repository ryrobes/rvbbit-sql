def cmd_catalog_search(args: argparse.Namespace) -> None:
    entries = load_catalog(Path(args.root))
    terms = args.terms
    for entry in entries:
        if terms and not matches_entry(entry, terms):
            continue
        tags = ",".join(entry.get("tags") or [])
        capability_name = entry.get("backend_name") or entry.get("runtime_name") or ""
        print(
            f"{entry['id']}\t{capability_name}\t{entry['source_model'] or ''}\t{tags}\t{entry['title']}"
        )


def render_catalog_publish_sql(root: Path, source: str, prune: bool) -> tuple[str, list[str]]:
    lines = ["-- Publish curated capability catalog into rvbbit.capability_catalog."]
    ids: list[str] = []
    for _path, manifest, entry in iter_catalog_manifests(root):
        ids.append(entry["id"])
        lines.extend(
            [
                "SELECT rvbbit.upsert_capability_catalog_entry(",
                f"  catalog_entry       => {sql_json(entry)},",
                f"  capability_manifest => {sql_json(install_manifest(manifest, entry.get('resources')))},",
                f"  catalog_source      => {sql_lit(source)},",
                "  entry_active        => true",
                ");",
                "",
            ]
        )
    if prune:
        lines.extend(
            [
                "SELECT rvbbit.prune_capability_catalog(",
                f"  catalog_source => {sql_lit(source)},",
                f"  keep_ids       => {sql_text_array(ids)}",
                ");",
                "",
            ]
        )
    return "\n".join(lines), ids


def cmd_catalog_publish(args: argparse.Namespace) -> None:
    root = Path(args.root)
    sql, ids = render_catalog_publish_sql(root, args.source, args.prune)
    if args.print_sql:
        print(sql, end="")
        return
    dsn = args.dsn or os.environ.get("RVBBIT_DSN")
    if not dsn:
        raise SystemExit("set --dsn or RVBBIT_DSN, or pass --print-sql")
    psql_exec_sql(dsn, sql)
    print(f"published {len(ids)} catalog entries")


def cmd_install(args: argparse.Namespace) -> None:
    manifest_path = Path(args.manifest)
    manifest = load_manifest(manifest_path)
    out_dir = Path(args.out_dir or Path(".rvbbit") / "capabilities" / manifest["name"])
    scaffold(manifest, out_dir, force=args.force)
    print(f"wrote {out_dir}")

    if not args.no_compose:
        compose_cmd = ["docker", "compose", "-f", "compose.yaml"]
        if args.gpu:
            compose_cmd.extend(["-f", "compose.gpu.yaml"])
        compose_cmd.extend(["up", "-d"])
        if not runtime_image(manifest.get("runtime") or {}):
            compose_cmd.append("--build")
        run_command(compose_cmd, cwd=out_dir)

    if args.no_sql:
        return

    dsn = args.dsn or os.environ.get("RVBBIT_DSN")
    if not dsn:
        raise SystemExit("set --dsn or RVBBIT_DSN, or pass --no-sql")
    psql_apply(dsn, out_dir / "register.sql")
    psql_apply(dsn, out_dir / "operator.sql")
    if not args.no_smoke:
        psql_apply(dsn, out_dir / "smoke.sql")


def cmd_deploy(args: argparse.Namespace) -> None:
    manifest = load_manifest(Path(args.manifest))
    try:
        target = json.loads(args.target)
    except json.JSONDecodeError as exc:
        raise SystemExit(f"--target must be JSON: {exc}") from exc
    if not isinstance(target, dict):
        raise SystemExit("--target must be a JSON object")

    sql = render_deploy_sql(manifest, target, args.job_name)
    if args.print_sql:
        print(sql, end="")
        return

    dsn = args.dsn or os.environ.get("RVBBIT_DSN")
    if not dsn:
        raise SystemExit("set --dsn or RVBBIT_DSN, or pass --print-sql")
    job_id = psql_scalar(dsn, sql)
    print(job_id)


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="rvbbit-capability")
    sub = parser.add_subparsers(required=True)

    p_render = sub.add_parser("render", help="render SQL/config from a manifest")
    p_render.add_argument("manifest")
    p_render.add_argument(
        "--part",
        choices=[
            "all",
            "register",
            "operators",
            "smoke",
            "compose",
            "compose-gpu",
            "deploy",
        ],
        default="all",
    )
    p_render.add_argument("--target", default="{}")
    p_render.add_argument("--job-name")
    p_render.set_defaults(func=cmd_render)

    p_scaffold = sub.add_parser("scaffold", help="write a runnable sidecar bundle")
    p_scaffold.add_argument("manifest")
    p_scaffold.add_argument("out_dir")
    p_scaffold.add_argument("--force", action="store_true")
    p_scaffold.set_defaults(func=cmd_scaffold)

    p_install = sub.add_parser("install", help="scaffold, optionally run compose, and apply SQL")
    p_install.add_argument("manifest")
    p_install.add_argument("--out-dir")
    p_install.add_argument("--dsn")
    p_install.add_argument("--force", action="store_true")
    p_install.add_argument("--gpu", action="store_true")
    p_install.add_argument("--no-compose", action="store_true")
    p_install.add_argument("--no-sql", action="store_true")
    p_install.add_argument("--no-smoke", action="store_true")
    p_install.set_defaults(func=cmd_install)

    p_deploy = sub.add_parser("deploy", help="queue a capability deployment for Warren")
    p_deploy.add_argument("manifest")
    p_deploy.add_argument("--dsn")
    p_deploy.add_argument("--target", default="{}")
    p_deploy.add_argument("--job-name")
    p_deploy.add_argument("--print-sql", action="store_true")
    p_deploy.set_defaults(func=cmd_deploy)

    p_test = sub.add_parser("test", help="deploy a pack through Warren and run pack acceptance SQL")
    p_test.add_argument("pack")
    p_test.add_argument("--dsn")
    p_test.add_argument("--target")
    p_test.add_argument("--job-name")
    p_test.add_argument("--no-deploy", action="store_true")
    p_test.add_argument("--no-warren", action="store_true")
    p_test.add_argument("--node", default=os.environ.get("WARREN_NODE", "capability-test-warren"))
    p_test.add_argument("--work-dir", default=os.environ.get("WARREN_WORK_DIR", ".rvbbit/warren-test"))
    p_test.add_argument(
        "--docker-network",
        default=os.environ.get("RVBBIT_DOCKER_NETWORK", "docker_default"),
    )
    p_test.add_argument(
        "--labels",
        default=os.environ.get(
            "WARREN_LABELS", '{"capability":true,"docker":true,"gpu":false}'
        ),
    )
    p_test.add_argument("--capacity", default=os.environ.get("WARREN_CAPACITY", "{}"))
    p_test.add_argument("--metrics-ms", type=int, default=int(os.environ.get("WARREN_METRICS_MS", "1000")))
    p_test.set_defaults(func=cmd_test)

    p_test_all = sub.add_parser(
        "test-all",
        help="run Warren acceptance SQL for every selected capability pack",
    )
    p_test_all.add_argument("--root", default=str(PACKS))
    p_test_all.add_argument("--dsn")
    p_test_all.add_argument(
        "--visibility",
        default="public",
        help="comma-separated catalog_visibility values to include",
    )
    p_test_all.add_argument("--include-gpu", action="store_true")
    p_test_all.add_argument("--only", action="append", help="require substring in pack id/name/path")
    p_test_all.add_argument("--skip", action="append", help="skip substring in pack id/name/path")
    p_test_all.add_argument("--target", help="override all pack acceptance target selectors")
    p_test_all.add_argument("--no-deploy", action="store_true")
    p_test_all.add_argument("--no-warren", action="store_true")
    p_test_all.add_argument("--fail-fast", action="store_true")
    p_test_all.add_argument("--out-dir", default=".rvbbit/capability-acceptance")
    p_test_all.add_argument("--node", default=os.environ.get("WARREN_NODE", "capability-test-warren"))
    p_test_all.add_argument("--work-dir", default=os.environ.get("WARREN_WORK_DIR", ".rvbbit/warren-test-all"))
    p_test_all.add_argument(
        "--docker-network",
        default=os.environ.get("RVBBIT_DOCKER_NETWORK", "docker_default"),
    )
    p_test_all.add_argument(
        "--labels",
        default=os.environ.get(
            "WARREN_LABELS", '{"capability":true,"docker":true,"gpu":false}'
        ),
    )
    p_test_all.add_argument("--capacity", default=os.environ.get("WARREN_CAPACITY", "{}"))
    p_test_all.add_argument("--metrics-ms", type=int, default=int(os.environ.get("WARREN_METRICS_MS", "1000")))
    p_test_all.set_defaults(func=cmd_test_all)

    p_list = sub.add_parser("list", help="list curated packs")
    p_list.add_argument("--root", default=str(PACKS))
    p_list.set_defaults(func=cmd_list)

    p_catalog = sub.add_parser("catalog", help="build, publish, or search a capability catalog")
    catalog_sub = p_catalog.add_subparsers(required=True)

    p_catalog_build = catalog_sub.add_parser("build", help="build catalog JSON")
    p_catalog_build.add_argument("--root", default=str(PACKS))
    p_catalog_build.add_argument("--output", "-o")
    p_catalog_build.add_argument("--timestamp", action="store_true")
    p_catalog_build.add_argument(
        "--image-prefix",
        help="emit image-mode runtime refs with this registry namespace, e.g. ghcr.io/ryrobes",
    )
    p_catalog_build.add_argument("--image-tag", default="latest")
    p_catalog_build.add_argument("--image-pull-policy", default="missing")
    p_catalog_build.set_defaults(func=cmd_catalog_build)

    p_catalog_search = catalog_sub.add_parser("search", help="search curated manifests")
    p_catalog_search.add_argument("terms", nargs="*")
    p_catalog_search.add_argument("--root", default=str(PACKS))
    p_catalog_search.set_defaults(func=cmd_catalog_search)

    p_catalog_seed = catalog_sub.add_parser("seed-json", help="build extension seed JSON")
    p_catalog_seed.add_argument("--root", default=str(PACKS))
    p_catalog_seed.add_argument("--source", default="curated")
    p_catalog_seed.add_argument("--output")
    p_catalog_seed.add_argument(
        "--image-prefix",
        help="emit image-mode runtime refs with this registry namespace, e.g. ghcr.io/ryrobes",
    )
    p_catalog_seed.add_argument("--image-tag", default="latest")
    p_catalog_seed.add_argument("--image-pull-policy", default="missing")
    p_catalog_seed.set_defaults(func=cmd_catalog_seed_json)

    p_catalog_publish = catalog_sub.add_parser("publish", help="publish catalog into Postgres")
    p_catalog_publish.add_argument("--root", default=str(PACKS))
    p_catalog_publish.add_argument("--dsn")
    p_catalog_publish.add_argument("--source", default="curated")
    p_catalog_publish.add_argument("--prune", action="store_true")
    p_catalog_publish.add_argument("--print-sql", action="store_true")
    p_catalog_publish.set_defaults(func=cmd_catalog_publish)

    args = parser.parse_args(argv)
    args.func(args)
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
