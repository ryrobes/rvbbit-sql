def manifest_relpath(path: Path, root: Path) -> str:
    try:
        return str(path.resolve().relative_to(root.resolve()))
    except ValueError:
        return str(path)


def repo_relpath(path: Path) -> str:
    try:
        return str(path.resolve().relative_to(REPO_ROOT.resolve())).replace("\\", "/")
    except ValueError:
        return str(path).replace("\\", "/")


def int_or_none(value: Any) -> int | None:
    if value is None or value == "":
        return None
    try:
        return int(value)
    except (TypeError, ValueError):
        return None


def number_or_none(value: Any) -> int | float | None:
    if value is None or value == "":
        return None
    try:
        parsed = float(value)
    except (TypeError, ValueError):
        return None
    if parsed.is_integer():
        return int(parsed)
    return parsed


def gpu_resource_fields(resources: dict[str, Any], device: str | None) -> dict[str, Any]:
    gpu = resources.get("gpu") if isinstance(resources, dict) else None
    if not isinstance(gpu, dict):
        gpu = {}
    gpu_required = bool(gpu.get("required")) or device == "cuda"
    placement = gpu.get("placement")
    return {
        "gpu_required": gpu_required,
        "gpu_placement": str(placement) if placement not in {None, ""} else None,
        "model_size_bytes": int_or_none(gpu.get("model_size_bytes")),
        "vram_required_bytes": int_or_none(gpu.get("vram_required_bytes")),
        "vram_headroom_pct": number_or_none(gpu.get("headroom_pct")),
    }


def capability_image_name(entry: dict[str, Any]) -> str:
    catalog_id = str(entry.get("id") or "")
    if catalog_id == "runtimes/python-runtime":
        return "rvbbit-python-runtime"
    if catalog_id == "runtimes/mcp-gateway":
        return "rvbbit-mcp-gateway"
    if catalog_id == "smoke/warren-echo":
        return "rvbbit-warren-smoke-echo"
    name = str(entry.get("name") or catalog_id).strip().lower()
    name = re.sub(r"[^a-z0-9]+", "-", name).strip("-")
    if not name:
        name = "capability"
    return f"rvbbit-capability-{name}"


def capability_image_ref(
    entry: dict[str, Any],
    image_prefix: str | None,
    image_tag: str | None,
) -> str | None:
    if not image_prefix:
        return None
    prefix = image_prefix.rstrip("/")
    tag = image_tag or "latest"
    return f"{prefix}/{capability_image_name(entry)}:{tag}"


def image_release_entry_manifest(
    entry: dict[str, Any],
    manifest: dict[str, Any],
    image_prefix: str | None,
    image_tag: str | None,
    pull_policy: str,
) -> tuple[dict[str, Any], dict[str, Any]]:
    if runtime_image(manifest.get("runtime") or {}):
        return entry, manifest
    image = capability_image_ref(entry, image_prefix, image_tag)
    if not image:
        return entry, manifest
    release_entry = copy.deepcopy(entry)
    release_manifest = copy.deepcopy(manifest)

    runtime = release_manifest.setdefault("runtime", {})
    if not isinstance(runtime, dict):
        runtime = {}
        release_manifest["runtime"] = runtime
    runtime["mode"] = "image"
    runtime["image"] = image
    runtime["pull_policy"] = pull_policy

    release_entry["runtime_mode"] = "image"
    release_entry["install_mode"] = "image"
    release_entry["runtime_image"] = image
    return release_entry, release_manifest


def catalog_entry(
    path: Path,
    root: Path,
    manifest: dict[str, Any],
    pack_path: Path | None = None,
    pack: dict[str, Any] | None = None,
) -> dict[str, Any]:
    rel = manifest_relpath(path, root).replace("\\", "/")
    manifest_path = repo_relpath(path)
    source = manifest.get("source") or {}
    runtime = manifest.get("runtime") or {}
    backend = manifest.get("backend") or {}
    operators = manifest.get("operators") or []
    provider_registration = manifest.get("provider_registration") or {}
    pack_source = (pack or {}).get("source") or {}
    pack_runtime = (pack or {}).get("runtime") or {}
    pack_exports = (pack or {}).get("exports") or {}
    pack_install = (pack or {}).get("install") or {}
    pack_acceptance = (pack or {}).get("acceptance") or {}
    resources = (pack or {}).get("resources") or manifest.get("resources") or {}
    device = pack_runtime.get("device") or runtime.get("device", "auto")
    gpu_fields = gpu_resource_fields(resources, device)
    acceptance_tests = [
        test.get("name")
        for test in pack_acceptance.get("tests") or []
        if isinstance(test, dict) and test.get("name")
    ]
    acceptance = None
    if isinstance(pack_acceptance, dict) and pack_acceptance:
        acceptance = {
            "target_selector": pack_acceptance.get("target_selector") or {},
            "setup_sql": pack_acceptance.get("setup_sql") or [],
            "tests": [
                {
                    "name": test.get("name"),
                    "description": test.get("description"),
                    "sql": test.get("sql"),
                }
                for test in pack_acceptance.get("tests") or []
                if isinstance(test, dict) and test.get("name") and test.get("sql")
            ],
            "teardown_sql": pack_acceptance.get("teardown_sql") or [],
        }
    runtime_mode = pack_install.get("mode") or ("image" if runtime_image(runtime) else "build")
    return {
        "id": (pack or {}).get("id") or rel,
        "pack_id": (pack or {}).get("id"),
        "pack_path": repo_relpath(pack_path.parent) if pack_path else None,
        "pack_manifest_path": repo_relpath(pack_path) if pack_path else None,
        "pack_api_version": (pack or {}).get("api_version"),
        "catalog_visibility": (pack or {}).get("catalog_visibility") or "public",
        "name": (pack or {}).get("name") or manifest["name"],
        "title": (pack or {}).get("title") or manifest.get("title") or manifest["name"],
        "description": (pack or {}).get("description") or manifest.get("description"),
        "tags": (pack or {}).get("tags") or manifest.get("tags") or [],
        "kind": manifest.get("kind"),
        "source_provider": pack_source.get("provider") or source.get("provider"),
        "source_model": pack_source.get("model") or source.get("model"),
        "source_revision": pack_source.get("revision") or source.get("revision"),
        "source_url": pack_source.get("url") or source.get("url"),
        "repo_url": (pack or {}).get("repo_url"),
        "system_runtime": bool((pack or {}).get("system_runtime") or manifest.get("system_runtime")),
        "capability_role": (pack or {}).get("capability_role") or manifest.get("capability_role"),
        "license": (pack or {}).get("license") or manifest.get("license"),
        "backend_name": pack_exports.get("backend") or backend.get("name"),
        "backend_transport": backend.get("transport", "rvbbit"),
        "provider_name": provider_registration.get("provider"),
        "provider_model": provider_registration.get("model"),
        "provider_set_default": bool(provider_registration.get("set_default")),
        "runtime_name": pack_exports.get("runtime")
        or (manifest.get("runtime_registration") or {}).get("name"),
        "runtime_language": (manifest.get("runtime_registration") or {}).get("language")
        or runtime.get("language"),
        "runtime_image": runtime_image(runtime),
        "runtime_mode": runtime_mode,
        "runtime_template": runtime.get("template", "hf-rvbbit-fastapi"),
        "runtime_handler": pack_runtime.get("handler") or runtime.get("handler", "custom"),
        "runtime_port": pack_runtime.get("port") or runtime.get("port"),
        "health_path": pack_runtime.get("health_path") or runtime.get("health_path"),
        "resources": resources,
        **gpu_fields,
        "install_mode": runtime_mode,
        "install_warren": pack_install.get("warren"),
        "install_docker": pack_install.get("docker"),
        "acceptance_tests": acceptance_tests,
        "acceptance": acceptance,
        "endpoint_path": (manifest.get("warren") or {}).get("endpoint_path")
        or (manifest.get("runtime_registration") or {}).get("endpoint_path"),
        "device": device,
        "operators": pack_exports.get("operators")
        or [op.get("name") for op in operators if op.get("name")],
        "manifest_path": manifest_path,
    }


def discover_pack_manifests(root: Path) -> list[Path]:
    pack_path = find_pack_manifest(root)
    if pack_path:
        return [pack_path]
    if not root.exists() or not root.is_dir():
        return []
    paths: list[Path] = []
    for name in PACK_MANIFEST_NAMES:
        paths.extend(root.rglob(name))
    return sorted(set(paths))


def iter_catalog_manifests(root: Path):
    pack_paths = discover_pack_manifests(root)
    if pack_paths:
        for pack_path in pack_paths:
            try:
                pack = load_pack_metadata(pack_path)
                manifest_path = pack_capability_path(pack_path, pack)
                manifest = load_manifest(manifest_path)
            except SystemExit:
                raise
            yield manifest_path, manifest, catalog_entry(
                manifest_path, root, manifest, pack_path, pack
            )
        return

    for path in sorted(root.rglob("*.yaml")) + sorted(root.rglob("*.json")):
        try:
            manifest = load_manifest(path)
        except SystemExit:
            continue
        yield path, manifest, catalog_entry(path, root, manifest)


def load_catalog(
    root: Path,
    image_prefix: str | None = None,
    image_tag: str | None = None,
    image_pull_policy: str = "missing",
) -> list[dict[str, Any]]:
    entries: list[dict[str, Any]] = []
    for _path, manifest, entry in iter_catalog_manifests(root):
        entry, _manifest = image_release_entry_manifest(
            entry, manifest, image_prefix, image_tag, image_pull_policy
        )
        entries.append(entry)
    return entries


def catalog_doc(
    root: Path,
    include_timestamp: bool = False,
    image_prefix: str | None = None,
    image_tag: str | None = None,
    image_pull_policy: str = "missing",
) -> dict[str, Any]:
    doc: dict[str, Any] = {
        "schema_version": 1,
        "catalog_layout": "rvbbit.pack/v1",
        "capabilities": load_catalog(root, image_prefix, image_tag, image_pull_policy),
    }
    if include_timestamp:
        from datetime import datetime, timezone

        doc["generated_at"] = datetime.now(timezone.utc).isoformat()
    return doc


def catalog_seed_doc(
    root: Path,
    source: str,
    image_prefix: str | None = None,
    image_tag: str | None = None,
    image_pull_policy: str = "missing",
) -> dict[str, Any]:
    entries = []
    for _path, manifest, entry in iter_catalog_manifests(root):
        entry, manifest = image_release_entry_manifest(
            entry, manifest, image_prefix, image_tag, image_pull_policy
        )
        entries.append(
            {
                "catalog_entry": entry,
                "capability_manifest": install_manifest(manifest, entry.get("resources")),
            }
        )
    return {
        "schema_version": 1,
        "catalog_layout": "rvbbit.pack/v1",
        "catalog_source": source,
        "capabilities": entries,
    }


def matches_entry(entry: dict[str, Any], terms: list[str]) -> bool:
    haystack = json.dumps(entry, sort_keys=True).lower()
    return all(term.lower() in haystack for term in terms)


def run_command(cmd: list[str], cwd: Path | None = None) -> None:
    print("+ " + " ".join(cmd), file=sys.stderr)
    subprocess.run(cmd, cwd=str(cwd) if cwd else None, check=True)


def psql_apply(dsn: str, sql_file: Path) -> None:
    run_command(["psql", dsn, "-v", "ON_ERROR_STOP=1", "-f", str(sql_file)])


def psql_scalar(dsn: str, sql: str) -> str:
    print("+ psql <deploy-sql>", file=sys.stderr)
    result = subprocess.run(
        ["psql", dsn, "-v", "ON_ERROR_STOP=1", "-At", "-c", sql],
        check=True,
        text=True,
        stdout=subprocess.PIPE,
    )
    return result.stdout.strip()


def psql_exec_sql(dsn: str, sql: str) -> None:
    print("+ psql <catalog-sql>", file=sys.stderr)
    subprocess.run(
        ["psql", dsn, "-v", "ON_ERROR_STOP=1", "-q", "-o", "/dev/null"],
        check=True,
        text=True,
        input=sql,
    )


def psql_capture_sql(dsn: str, sql: str) -> str:
    result = subprocess.run(
        ["psql", dsn, "-v", "ON_ERROR_STOP=1", "-P", "pager=off"],
        check=True,
        text=True,
        input=sql,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    output = (result.stdout or "").strip()
    errors = (result.stderr or "").strip()
    if errors:
        return f"{output}\n{errors}".strip()
    return output


def warren_job_result(dsn: str, job_id: str) -> dict[str, Any]:
    text = psql_scalar(
        dsn,
        "\n".join(
            [
                "SELECT jsonb_build_object(",
                "  'job_id', job_id::text,",
                "  'status', status,",
                "  'phase', phase,",
                "  'error', error,",
                "  'backend_name', backend_name,",
                "  'operator_name', operator_name,",
                "  'runtime_name', runtime_name,",
                "  'endpoint_url', endpoint_url,",
                "  'progress', progress,",
                "  'logs', logs",
                ")::text",
                "FROM rvbbit.warren_jobs",
                f"WHERE job_id = {sql_lit(job_id)}::uuid",
            ]
        ),
    )
    if not text:
        return {"job_id": job_id, "status": "missing", "error": "job row not found"}
    return json.loads(text)


def run_warren_once(args: argparse.Namespace) -> None:
    command = [
        "cargo",
        "run",
        "-p",
        "warren-agent",
        "--",
        "--dsn",
        args.dsn,
        "--node",
        args.node,
        "--work-dir",
        args.work_dir,
        "--docker-network",
        args.docker_network,
        "--labels",
        args.labels,
        "--capacity",
        args.capacity,
        "--metrics-ms",
        str(args.metrics_ms),
        "--once",
    ]
    run_command(command, cwd=REPO_ROOT)


def cmd_test(args: argparse.Namespace) -> None:
    pack_path, pack, _manifest_path, manifest = load_pack_and_manifest(Path(args.pack))
    acceptance = pack.get("acceptance") or {}
    tests = acceptance.get("tests") or []
    if not isinstance(tests, list) or not tests:
        raise SystemExit(f"{args.pack}: pack has no acceptance.tests")

    dsn = args.dsn or os.environ.get("RVBBIT_DSN")
    if not dsn:
        raise SystemExit("set --dsn or RVBBIT_DSN")
    args.dsn = dsn

    target = json.loads(args.target) if args.target else acceptance.get("target_selector") or {}
    if not isinstance(target, dict):
        raise SystemExit("acceptance target_selector/--target must be a JSON object")

    pack_id = pack.get("id") or manifest["name"]
    job_name = args.job_name or (
        "accept-"
        + str(pack_id).replace("/", "-").replace("_", "-")[:42]
        + "-"
        + dt.datetime.now(dt.timezone.utc).strftime("%Y%m%d%H%M%S")
    )
    events: list[dict[str, Any]] = []

    def event(step: str, status: str, **details: Any) -> None:
        doc = {"step": step, "status": status, **details}
        events.append(doc)
        print(json.dumps(doc, sort_keys=True), flush=True)

    if not args.no_deploy:
        sql = render_deploy_sql(manifest, target, job_name)
        job_id = psql_scalar(dsn, sql)
        event("deploy", "ok", job_id=job_id, job_name=job_name, target_selector=target)
        if not args.no_warren:
            try:
                run_warren_once(args)
            except subprocess.CalledProcessError as exc:
                job_doc = warren_job_result(dsn, job_id)
                event(
                    "warren_once",
                    "fail",
                    node=args.node,
                    work_dir=args.work_dir,
                    job=job_doc,
                    returncode=exc.returncode,
                )
                raise SystemExit(exc.returncode) from exc
            job_doc = warren_job_result(dsn, job_id)
            if job_doc.get("status") != "completed":
                event("warren_once", "fail", node=args.node, work_dir=args.work_dir, job=job_doc)
                raise SystemExit(1)
            event("warren_once", "ok", node=args.node, work_dir=args.work_dir, job=job_doc)

    for idx, sql in enumerate(acceptance.get("setup_sql") or [], start=1):
        output = psql_capture_sql(dsn, sql)
        event(f"setup_{idx}", "ok", output=output[-2000:])

    failures = 0
    for test in tests:
        if not isinstance(test, dict):
            raise SystemExit(f"{args.pack}: acceptance test must be an object")
        name = test.get("name") or "unnamed"
        sql = test.get("sql")
        if not isinstance(sql, str) or not sql.strip():
            raise SystemExit(f"{args.pack}: acceptance test {name!r} missing sql")
        try:
            output = psql_capture_sql(dsn, sql)
        except subprocess.CalledProcessError as exc:
            failures += 1
            event(
                str(name),
                "fail",
                stdout=(exc.stdout or "")[-2000:],
                stderr=(exc.stderr or "")[-2000:],
            )
        else:
            event(str(name), "ok", output=output[-2000:])

    for idx, sql in enumerate(acceptance.get("teardown_sql") or [], start=1):
        try:
            output = psql_capture_sql(dsn, sql)
        except subprocess.CalledProcessError as exc:
            failures += 1
            event(
                f"teardown_{idx}",
                "fail",
                stdout=(exc.stdout or "")[-2000:],
                stderr=(exc.stderr or "")[-2000:],
            )
        else:
            event(f"teardown_{idx}", "ok", output=output[-2000:])

    summary = {
        "pack": pack_id,
        "pack_path": str(pack_path) if pack_path else None,
        "tests": len(tests),
        "failures": failures,
    }
    event("summary", "fail" if failures else "ok", **summary)
    if failures:
        raise SystemExit(1)


def safe_slug(value: str) -> str:
    return "".join(c if c.isalnum() else "-" for c in value).strip("-").lower() or "capability"


def pack_operator_coverage(pack: dict[str, Any], manifest: dict[str, Any]) -> dict[str, Any]:
    operators = (pack.get("exports") or {}).get("operators") or [
        op.get("name") for op in manifest.get("operators") or [] if op.get("name")
    ]
    acceptance = pack.get("acceptance") or {}
    sql_parts: list[str] = []
    sql_parts.extend(
        str(test.get("sql"))
        for test in acceptance.get("tests") or []
        if isinstance(test, dict) and test.get("sql")
    )
    haystack = "\n".join(sql_parts)
    covered = []
    for op in operators:
        op = str(op)
        pattern = re.compile(
            rf"(?<![A-Za-z0-9_])(?:rvbbit\.)?{re.escape(op)}\s*\(",
            re.IGNORECASE,
        )
        if pattern.search(haystack):
            covered.append(op)
    return {
        "operators": operators,
        "covered_operators": sorted(set(covered)),
        "uncovered_operators": sorted(set(map(str, operators)) - set(covered)),
    }


def pack_requires_gpu(pack: dict[str, Any], manifest: dict[str, Any]) -> bool:
    acceptance = pack.get("acceptance") or {}
    target = acceptance.get("target_selector") or {}
    runtime = manifest.get("runtime") or {}
    return target.get("gpu") is True or runtime.get("device") == "cuda"


def cmd_test_all(args: argparse.Namespace) -> None:
    dsn = args.dsn or os.environ.get("RVBBIT_DSN")
    if not dsn:
        raise SystemExit("set --dsn or RVBBIT_DSN")

    root = Path(args.root)
    visibilities = {v.strip() for v in args.visibility.split(",") if v.strip()}
    only_terms = [term.lower() for term in (args.only or [])]
    skip_terms = [term.lower() for term in (args.skip or [])]
    out_dir = Path(args.out_dir)
    out_dir.mkdir(parents=True, exist_ok=True)
    started = dt.datetime.now(dt.timezone.utc)
    run_id = started.strftime("capability_acceptance_%Y%m%dT%H%M%SZ")
    jsonl_path = out_dir / f"{run_id}.jsonl"
    summary_path = out_dir / f"{run_id}.summary.json"
    report_path = out_dir / f"{run_id}.md"
    results: list[dict[str, Any]] = []

    def write_result(result: dict[str, Any]) -> None:
        results.append(result)
        with jsonl_path.open("a", encoding="utf-8") as f:
            f.write(json.dumps(result, sort_keys=True) + "\n")
        print(json.dumps(result, sort_keys=True), flush=True)

    for pack_path in discover_pack_manifests(root):
        pack = load_pack_metadata(pack_path)
        manifest_path = pack_capability_path(pack_path, pack)
        manifest = load_manifest(manifest_path)
        pack_id = str(pack.get("id") or manifest.get("name") or pack_path.parent.name)
        searchable = " ".join(
            [
                pack_id,
                str(pack.get("name") or ""),
                str(pack.get("title") or ""),
                str(pack_path.parent),
            ]
        ).lower()
        visibility = str(pack.get("catalog_visibility") or "public")
        acceptance = pack.get("acceptance") or {}
        tests = acceptance.get("tests") or []
        coverage = pack_operator_coverage(pack, manifest)
        base = {
            "pack": pack_id,
            "pack_path": repo_relpath(pack_path.parent),
            "visibility": visibility,
            "target_selector": acceptance.get("target_selector") or {},
            "operator_coverage": coverage,
        }
        if visibility not in visibilities:
            write_result({**base, "status": "skip", "reason": f"visibility {visibility} not selected"})
            continue
        if only_terms and not all(term in searchable for term in only_terms):
            write_result({**base, "status": "skip", "reason": "--only filter"})
            continue
        if skip_terms and any(term in searchable for term in skip_terms):
            write_result({**base, "status": "skip", "reason": "--skip filter"})
            continue
        if pack_requires_gpu(pack, manifest) and not args.include_gpu:
            write_result({**base, "status": "skip", "reason": "requires gpu; pass --include-gpu"})
            continue
        if not isinstance(tests, list) or not tests:
            write_result({**base, "status": "skip", "reason": "no acceptance.tests"})
            continue

        command = [
            sys.executable,
            str(Path(__file__).resolve()),
            "test",
            str(pack_path.parent),
            "--dsn",
            dsn,
            "--node",
            args.node,
            "--work-dir",
            str(Path(args.work_dir) / safe_slug(pack_id)),
            "--docker-network",
            args.docker_network,
            "--labels",
            args.labels,
            "--capacity",
            args.capacity,
            "--metrics-ms",
            str(args.metrics_ms),
        ]
        if args.target:
            command.extend(["--target", args.target])
        if args.no_deploy:
            command.append("--no-deploy")
        if args.no_warren:
            command.append("--no-warren")

        t0 = dt.datetime.now(dt.timezone.utc)
        proc = subprocess.run(command, text=True, capture_output=True, check=False)
        duration_ms = int((dt.datetime.now(dt.timezone.utc) - t0).total_seconds() * 1000)
        events: list[dict[str, Any]] = []
        for line in (proc.stdout or "").splitlines():
            try:
                events.append(json.loads(line))
            except json.JSONDecodeError:
                events.append({"step": "stdout", "status": "info", "line": line})
        result = {
            **base,
            "status": "ok" if proc.returncode == 0 else "fail",
            "duration_ms": duration_ms,
            "returncode": proc.returncode,
            "events": events,
            "stderr_tail": (proc.stderr or "")[-4000:],
        }
        write_result(result)
        if proc.returncode != 0 and args.fail_fast:
            break

    failures = [r for r in results if r["status"] == "fail"]
    skipped = [r for r in results if r["status"] == "skip"]
    ok = [r for r in results if r["status"] == "ok"]
    uncovered = [
        {
            "pack": r["pack"],
            "uncovered_operators": r["operator_coverage"]["uncovered_operators"],
        }
        for r in results
        if r["status"] != "skip" and r["operator_coverage"]["uncovered_operators"]
    ]
    summary = {
        "run_id": run_id,
        "started_at": started.isoformat(),
        "finished_at": dt.datetime.now(dt.timezone.utc).isoformat(),
        "root": str(root),
        "ok": len(ok),
        "failed": len(failures),
        "skipped": len(skipped),
        "total": len(results),
        "jsonl": str(jsonl_path),
        "report": str(report_path),
        "operator_coverage_gaps": uncovered,
    }
    summary_path.write_text(json.dumps(summary, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    lines = [
        f"# Capability Acceptance Sweep `{run_id}`",
        "",
        f"- ok: `{len(ok)}`",
        f"- failed: `{len(failures)}`",
        f"- skipped: `{len(skipped)}`",
        f"- jsonl: `{jsonl_path}`",
        "",
        "| Status | Pack | ms | Tests | Operator Coverage | Notes |",
        "|---|---|---:|---:|---|---|",
    ]
    for r in results:
        events = r.get("events") or []
        test_events = [
            e
            for e in events
            if e.get("step") not in {"deploy", "warren_once", "summary"}
            and not str(e.get("step", "")).startswith("setup_")
            and not str(e.get("step", "")).startswith("teardown_")
        ]
        coverage = r["operator_coverage"]
        covered = len(coverage["covered_operators"])
        total_ops = len(coverage["operators"])
        note = r.get("reason") or (r.get("stderr_tail") or "").splitlines()[-1:] or [""]
        if isinstance(note, list):
            note = note[0] if note else ""
        note = str(note).replace("|", "\\|")[:180]
        lines.append(
            f"| `{r['status']}` | `{r['pack']}` | {r.get('duration_ms', 0)} | "
            f"{len(test_events)} | `{covered}/{total_ops}` | {note} |"
        )
    if uncovered:
        lines.extend(["", "## Operator Coverage Gaps", ""])
        for item in uncovered:
            lines.append(
                f"- `{item['pack']}`: {', '.join(f'`{op}`' for op in item['uncovered_operators'])}"
            )
    report_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
    print(f"summary: {summary_path}", file=sys.stderr)
    print(f"report: {report_path}", file=sys.stderr)
    if failures:
        raise SystemExit(1)


def cmd_render(args: argparse.Namespace) -> None:
    manifest = load_manifest(Path(args.manifest))
    if args.part == "register":
        print(render_register_sql(manifest), end="")
    elif args.part == "operators":
        print(render_operator_sql(manifest), end="")
    elif args.part == "smoke":
        print(render_smoke_sql(manifest), end="")
    elif args.part == "compose":
        print(render_compose(manifest), end="")
    elif args.part == "compose-gpu":
        print(render_gpu_compose(manifest), end="")
    elif args.part == "deploy":
        target = json.loads(args.target)
        if not isinstance(target, dict):
            raise SystemExit("--target must be a JSON object")
        print(render_deploy_sql(manifest, target, args.job_name), end="")
    else:
        print(render_all(manifest), end="")


