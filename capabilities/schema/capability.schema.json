{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rvbbit.dev/schemas/capability.schema.json",
  "title": "Rvbbit Capability Manifest",
  "type": "object",
  "required": ["api_version", "kind", "name"],
  "additionalProperties": false,
  "properties": {
    "api_version": {
      "type": "string",
      "const": "rvbbit.capability/v1"
    },
    "kind": {
      "type": "string",
      "enum": ["hf_backend", "runtime_sidecar", "llm_provider"]
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_\\-]*$"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "system_runtime": {
      "type": "boolean",
      "default": false
    },
    "capability_role": {
      "type": "string",
      "enum": ["model_capability", "system_runtime", "operator_runtime"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source": {
      "type": "object",
      "required": ["provider", "model"],
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string", "enum": ["huggingface", "builtin", "openrouter"] },
        "model": { "type": "string" },
        "revision": { "type": "string" },
        "url": { "type": "string" }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string", "enum": ["image", "build", "external"] },
        "image": { "type": "string" },
        "image_digest": { "type": "string" },
        "pull_policy": {
          "type": "string",
          "enum": ["missing", "always", "never"]
        },
        "template": { "type": "string", "default": "hf-rvbbit-fastapi" },
        "handler": {
          "type": "string",
          "enum": [
            "embedding",
            "sequence_classification",
            "question_answering",
            "summarization",
            "token_classification",
            "table_question_answering",
            "zero_shot_classification",
            "gliner",
            "tabular_classification",
            "tabular_regression",
            "tabular_foundation",
            "time_series_forecast",
            "data_contract_miner",
            "semantic_column_type",
            "join_detective",
            "echo",
            "vllm_openai",
            "python_runtime",
            "mcp_gateway",
            "custom"
          ]
        },
        "device": { "type": "string", "enum": ["auto", "cpu", "cuda", "api"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "health_path": { "type": "string" },
        "language": { "type": "string" },
        "python_version": { "type": "string" },
        "volumes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "mount"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "mount": { "type": "string" }
            }
          }
        },
        "base_image": { "type": "string" },
        "command": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "args": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "ipc": { "type": "string" },
        "extra_requirements": {
          "type": "array",
          "items": { "type": "string" }
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gpu": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "required": { "type": "boolean" },
            "placement": { "type": "string", "enum": ["single_gpu"] },
            "model_size_bytes": { "type": "integer", "minimum": 0 },
            "vram_required_bytes": { "type": "integer", "minimum": 0 },
            "headroom_pct": { "type": "number", "minimum": 0 },
            "estimate_source": { "type": "string" },
            "notes": { "type": "string" }
          }
        }
      }
    },
    "runtime_registration": {
      "type": "object",
      "required": ["name", "language"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "language": { "type": "string", "enum": ["python", "mcp"] },
        "endpoint": { "type": "string" },
        "endpoint_path": { "type": "string" },
        "set_default": { "type": "boolean" },
        "labels": { "type": "object" }
      }
    },
    "backend": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "endpoint": { "type": "string" },
        "transport": { "type": "string", "default": "rvbbit" },
        "batch_size": { "type": "integer", "minimum": 1, "default": 32 },
        "max_concurrent": { "type": "integer", "minimum": 1, "default": 4 },
        "timeout_ms": { "type": "integer", "minimum": 100, "default": 60000 },
        "auth_env": { "type": ["string", "null"] },
        "opts": { "type": "object" },
        "description": { "type": "string" }
      }
    },
    "provider_registration": {
      "type": "object",
      "required": ["provider", "model"],
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string", "pattern": "^[a-z][a-z0-9_\\-]*$" },
        "model": { "type": "string" },
        "backend_name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "display_name": { "type": "string" },
        "family": { "type": "string" },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "context_window": { "type": "integer", "minimum": 1 },
        "output_token_limit": { "type": "integer", "minimum": 1 },
        "input_per_mtok": { "type": "number", "minimum": 0 },
        "output_per_mtok": { "type": "number", "minimum": 0 },
        "currency": { "type": "string" },
        "cost_policy": {
          "type": "string",
          "enum": ["free", "fixed", "model_rate", "provider_settled", "unknown"]
        },
        "set_default": { "type": "boolean", "default": false },
        "raw": { "type": "object" }
      }
    },
    "operators": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "arg_names", "return_type"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "description": { "type": "string" },
          "infix_symbol": { "type": ["string", "null"] },
          "infix_word": { "type": ["string", "null"] },
          "arg_names": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "arg_types": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "return_type": {
            "type": "string",
            "enum": ["bool", "text", "float8", "jsonb"]
          },
          "parser": {
            "type": "string",
            "enum": ["yes_no", "score_0_1", "raw_text", "strip", "json"]
          },
          "shape": {
            "type": "string",
            "enum": ["scalar", "aggregate", "dimension", "rowset", "query"],
            "default": "scalar"
          },
          "inputs": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "steps": {
            "type": "array",
            "items": { "type": "object" }
          },
          "tests": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      }
    },
    "smoke": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputs": {
          "type": "array",
          "items": { "type": "object" }
        },
        "sql": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "warren": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "port": { "type": "integer" },
        "container_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "endpoint_url": { "type": "string" },
        "endpoint_path": { "type": "string" },
        "health_path": { "type": "string" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "hf_backend" } } },
      "then": { "required": ["backend"] }
    },
    {
      "if": { "properties": { "kind": { "const": "runtime_sidecar" } } },
      "then": { "required": ["runtime", "runtime_registration"] }
    }
  ]
}
